# Copy to .env and fill in your keys
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
# OPENROUTER_API_KEY=sk-or-...
# BITGN_API_KEY=         # needed for PAC1 leaderboard
# LLM_PROVIDER=openai    # or "anthropic" or "openrouter"
# RUN_NAME=my-experiment  # experiment name (BitGN + Logfire)
# BENCH_ID=bitgn/pac1-dev  # or "bitgn/sandbox"
# LOGFIRE_TOKEN=         # Pydantic Logfire write token (https://logfire.pydantic.dev)
# VAULT_TAGS=0           # 1 to wrap MCP responses with <vault-file> metadata tags (always on for codex MCP server)
# CODEX_MULTI_STEP=off   # "on" to enable Plan→Execute→Verify phased reasoning in codex
# CODEX_REASONING_EFFORT=high  # low, medium, high, or xhigh
