# Copy to .env and fill in your keys
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENROUTER_API_KEY=sk-or-v1-...

BITGN_API_KEY=bgn-...

LLM_PROVIDER=codex    # or "anthropic" or "openrouter"

# MODEL_ID=claude-sonnet-4-6

LOGFIRE_TOKEN=pylf_v1_us_...
# bitgn/pac1-prod, bitgn/pac1-dev or bitgn/sandbox
BENCH_ID=bitgn/pac1-prod

VAULT_TAGS=1           # 1 to wrap MCP responses with <vault-file> metadata tags (always on for codex MCP server)
CODEX_MULTI_STEP=on   # "on" to enable Plan→Execute→Verify phased reasoning in codex
